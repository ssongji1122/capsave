{
  "name": "scrave-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@scrave/web",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "build:shared": "turbo build --filter=@scrave/shared"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
